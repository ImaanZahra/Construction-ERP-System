@model ConstructionERPSystem.Models.Invoice

<!DOCTYPE html>
<html>
<head>
    <title>Invoice Details - Construction ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: #F5F5F0;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 16px;
            }

            .page-wrap {
                width: 100%;
                max-width: 580px;
            }

            .page-eyebrow {
                font-size: 11px;
                font-weight: 600;
                color: #F5C518;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                margin-bottom: 6px;
            }

            .page-title {
                font-size: 26px;
                font-weight: 700;
                color: #111111;
                letter-spacing: -0.5px;
                margin-bottom: 4px;
            }

            .page-subtitle {
                font-size: 14px;
                color: #888888;
                margin-bottom: 24px;
            }

            .card {
                background: #FFFFFF;
                border-radius: 16px;
                box-shadow: 0 8px 40px rgba(0,0,0,0.08);
                overflow: hidden;
            }

            .invoice-avatar-row {
                background: #111111;
                padding: 28px 32px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
            }

            .avatar-block {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .avatar {
                width: 52px;
                height: 52px;
                background: #F5C518;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                font-weight: 700;
                color: #111111;
                flex-shrink: 0;
            }

            .avatar-name {
                color: #FFFFFF;
                font-size: 18px;
                font-weight: 700;
                letter-spacing: -0.3px;
            }

            .avatar-tag {
                font-size: 12px;
                color: #888888;
                margin-top: 2px;
            }

            .status-badge {
                font-size: 12px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                padding: 6px 14px;
                border-radius: 8px;
            }

            .status-paid {
                background: #E8F5E9;
                color: #2E7D32;
            }

            .status-partial {
                background: #FFF8E1;
                color: #B8860B;
            }

            .status-pending {
                background: #F5F5F0;
                color: #666666;
            }

            .status-overdue {
                background: #FFF3F3;
                color: #C62828;
            }

            .details-body {
                padding: 28px 32px;
            }

            .section-divider {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 20px;
            }

            .section-label {
                font-size: 11px;
                font-weight: 600;
                color: #BBBBBB;
                text-transform: uppercase;
                letter-spacing: 1px;
                white-space: nowrap;
            }

            .section-line {
                flex: 1;
                height: 1px;
                background: #E5E5E0;
            }

            .detail-row {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                padding: 13px 0;
                border-bottom: 1px solid #F0F0EC;
                gap: 16px;
            }

                .detail-row:last-child {
                    border-bottom: none;
                }

            .detail-key {
                font-size: 13px;
                font-weight: 500;
                color: #888888;
                white-space: nowrap;
                flex-shrink: 0;
            }

            .detail-val {
                font-size: 14px;
                font-weight: 500;
                color: #111111;
                text-align: right;
            }

            .form-actions {
                display: flex;
                gap: 12px;
                padding: 20px 32px 28px;
                border-top: 1px solid #E5E5E0;
            }

            .btn-edit {
                flex: 1;
                height: 46px;
                background: #F5C518;
                color: #111111;
                border: none;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                font-weight: 600;
                text-decoration: none;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: background 0.15s, transform 0.1s;
            }

                .btn-edit:hover {
                    background: #e6b800;
                    color: #111111;
                }

                .btn-edit:active {
                    transform: scale(0.99);
                }

            .btn-back {
                display: flex;
                align-items: center;
                justify-content: center;
                height: 46px;
                padding: 0 24px;
                background: #FFFFFF;
                color: #444444;
                border: 1.5px solid #E5E5E0;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                font-weight: 500;
                text-decoration: none;
                transition: border-color 0.15s, color 0.15s;
                white-space: nowrap;
            }

                .btn-back:hover {
                    border-color: #111111;
                    color: #111111;
                }

            @@media (max-width: 520px) {
                .invoice-avatar-row {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 16px;
                }

                .invoice-avatar-row, .details-body, .form-actions {
                    padding-left: 20px;
                    padding-right: 20px;
                }

                .form-actions {
                    flex-direction: column;
                }
            }
    </style>
</head>
<body>

    <div class="page-wrap">

        <p class="page-eyebrow">Billing</p>
        <h1 class="page-title">Invoice Details</h1>
        <p class="page-subtitle">Reviewing structural balance parameters for statement generation.</p>

        <div class="card">

            <div class="invoice-avatar-row">
                <div class="avatar-block">
                    <div class="avatar">INV</div>
                    <div>
                        <div class="avatar-name">@(string.IsNullOrEmpty(Model.ClientName) ? "Invoice Profile" : Model.ClientName)</div>
                        <div class="avatar-tag">Billing Unit &nbsp;#@Model.InvoiceId</div>
                    </div>
                </div>

                @{
                    string badgeClass = "status-pending";
                    if (Model.Status == "Paid") badgeClass = "status-paid";
                    else if (Model.Status == "Partially Paid") badgeClass = "status-partial";
                    else if (Model.Status == "Overdue") badgeClass = "status-overdue";
                }
                <span class="status-badge @badgeClass">@Model.Status</span>
            </div>

            <div class="details-body">

                <div class="section-divider">
                    <span class="section-label">Allocation Matrix</span>
                    <div class="section-line"></div>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Client Name</span>
                    <span class="detail-val" style="font-weight: 600;">@(string.IsNullOrEmpty(Model.ClientName) ? "—" : Model.ClientName)</span>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Project Link</span>
                    <span class="detail-val">@(string.IsNullOrEmpty(Model.ProjectName) ? "—" : Model.ProjectName)</span>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Statement Date</span>
                    <span class="detail-val">@Model.InvoiceDate</span>
                </div>

                <div class="section-divider" style="margin-top: 20px;">
                    <span class="section-label">Ledger Values</span>
                    <div class="section-line"></div>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Gross Total Amount</span>
                    <span class="detail-val" style="font-weight: 600;">
                        @Model.TotalAmount.ToString("N2")
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Receipted Paid Amount</span>
                    <span class="detail-val" style="color: #2E7D32;">
                        @Model.PaidAmount.ToString("N2")
                    </span>
                </div>

                <div class="detail-row">
                    @{
                        decimal netRemaining = Model.TotalAmount - Model.PaidAmount;
                    }
                    <span class="detail-key">Net Remaining Deficit</span>
                    <span class="detail-val" style="font-size: 16px; font-weight: 700; color: @(netRemaining > 0 ? "#C62828" : "#111111");">
                        @netRemaining.ToString("N2")
                    </span>
                </div>

            </div>

            <div class="form-actions">
                <a href="/Invoices" class="btn-back">← Back</a>
                <a href="/Invoices/Edit/@Model.InvoiceId" class="btn-edit">Edit Invoice →</a>
            </div>

        </div>
    </div>

</body>
</html>