@model ConstructionERPSystem.Models.TaskModel

<h2>Task Details</h2>

<table class="table table-bordered">

    <tr>
        <th>Task</th>
        <td>@Model.TaskTitle</td>
    </tr>

    <tr>
        <th>Project</th>
        <td>@Model.ProjectName</td>
    </tr>

    <tr>
        <th>Site</th>
        <td>@Model.SiteName</td>
    </tr>

    <tr>
        <th>Employee</th>
        <td>@Model.EmployeeName</td>
    </tr>

    <tr>
        <th>Description</th>
        <td>@Model.Description</td>
    </tr>

    <tr>
        <th>Priority</th>
        <td>@Model.Priority</td>
    </tr>

    <tr>
        <th>Status</th>
        <td>@Model.Status</td>
    </tr>

    <tr>
        <th>Progress</th>
        <td>@Model.Progress %</td>
    </tr>

<!DOCTYPE html>
<html>
<head>
    <title>Task Details - Construction ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #F5F5F0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
        }

        .page-wrap {
            width: 100%;
            max-width: 580px;
        }

        .page-eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #F5C518;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 26px;
            font-weight: 700;
            color: #111111;
            letter-spacing: -0.5px;
            margin-bottom: 4px;
        }

        .page-subtitle {
            font-size: 14px;
            color: #888888;
            margin-bottom: 24px;
        }

        .card {
            background: #FFFFFF;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .task-avatar-row {
            background: #111111;
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .avatar-block {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .avatar {
            width: 52px;
            height: 52px;
            background: #F5C518;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            color: #111111;
            flex-shrink: 0;
        }

        .avatar-name {
            color: #FFFFFF;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.3px;
        }

        .avatar-tag {
            font-size: 12px;
            color: #888888;
            margin-top: 2px;
        }

        /* Status and Priority Badges */
        .status-badge {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 6px 14px;
            border-radius: 8px;
        }
        .status-completed { background: #E8F5E9; color: #2E7D32; }
        .status-progress { background: #E3F2FD; color: #1565C0; }
        .status-pending { background: #F5F5F0; color: #666666; }

        .priority-flag {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            padding: 3px 8px;
            border-radius: 4px;
        }
        .priority-high { background: #FFF3F3; color: #C62828; }
        .priority-medium { background: #FFF8E1; color: #B8860B; }
        .priority-low { background: #F5F5F0; color: #666666; }

        .details-body {
            padding: 28px 32px;
        }

        .section-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }

        .section-label {
            font-size: 11px;
            font-weight: 600;
            color: #BBBBBB;
            text-transform: uppercase;
            letter-spacing: 1px; white-space: nowrap;
        }

        .section-line {
            flex: 1;
            height: 1px;
            background: #E5E5E0;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 13px 0;
            border-bottom: 1px solid #F0F0EC;
            gap: 16px;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-key {
            font-size: 13px;
            font-weight: 500;
            color: #888888;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .detail-val {
            font-size: 14px;
            font-weight: 500;
            color: #111111;
            text-align: right;
        }

        .progress-bar-container {
            width: 120px;
            height: 6px;
            background: #E5E5E0;
            border-radius: 3px;
            overflow: hidden;
            margin-top: 6px;
            margin-left: auto;
        }

        .progress-bar-fill {
            height: 100%;
            background: #111111;
            border-radius: 3px;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            padding: 20px 32px 28px;
            border-top: 1px solid #E5E5E0;
        }

        .btn-edit {
            flex: 1;
            height: 46px;
            background: #F5C518;
            color: #111111;
            border: none;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
        }

        .btn-edit:hover {
            background: #e6b800;
            color: #111111;
        }

        .btn-edit:active {
            transform: scale(0.99);
        }

        .btn-back {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 46px;
            padding: 0 24px;
            background: #FFFFFF;
            color: #444444;
            border: 1.5px solid #E5E5E0;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 500;
            text-decoration: none;
            transition: border-color 0.15s, color 0.15s;
            white-space: nowrap;
        }

        .btn-back:hover {
            border-color: #111111;
            color: #111111;
        }

        @@media (max-width: 520px) {
            .task-avatar-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 14px;
            }
            
            .task-avatar-row, .details-body, .form-actions {
                padding-left: 20px;
                padding-right: 20px;
            }

            .form-actions {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

    <div class="page-wrap">

        <p class="page-eyebrow">Workforce</p>
        <h1 class="page-title">Task Details</h1>
        <p class="page-subtitle">Evaluating operational benchmarks and individual deployment updates.</p>

        <div class="card">

            <div class="task-avatar-row">
                <div class="avatar-block">
                    <div class="avatar">@(string.IsNullOrEmpty(Model.TaskTitle) ? "T" : Model.TaskTitle.Substring(0, 1).ToUpper())</div>
                    <div>
                        <div class="avatar-name">@(string.IsNullOrEmpty(Model.TaskTitle) ? "Task Profile" : Model.TaskTitle)</div>
                        <div class="avatar-tag">Execution ID &nbsp;#@Model.TaskId</div>
                    </div>
                </div>

                @{
                    string badgeClass = "status-pending";
                    if (Model.Status == "Completed") badgeClass = "status-completed";
                    else if (Model.Status == "In Progress") badgeClass = "status-progress";
                }
                <span class="status-badge @badgeClass">@Model.Status</span>
            </div>

            <div class="details-body">

                <div class="section-divider">
                    <span class="section-label">Structural Mapping</span>
                    <div class="section-line"></div>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Project Context</span>
                    <span class="detail-val" style="font-weight: 600;">@(string.IsNullOrEmpty(Model.ProjectName) ? "—" : Model.ProjectName)</span>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Active Work Site</span>
                    <span class="detail-val">@(string.IsNullOrEmpty(Model.SiteName) ? "—" : Model.SiteName)</span>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Assigned Personnel</span>
                    <span class="detail-val">@(string.IsNullOrEmpty(Model.EmployeeName) ? "Unassigned" : Model.EmployeeName)</span>
                </div>

                <div class="section-divider" style="margin-top: 20px;">
                    <span class="section-label">Execution Metrics</span>
                    <div class="section-line"></div>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Urgency Tier</span>
                    @{
                        string priClass = "priority-medium";
                        if (Model.Priority == "High") priClass = "priority-high";
                        else if (Model.Priority == "Low") priClass = "priority-low";
                    }
                    <span class="detail-val"><span class="priority-flag @priClass">@Model.Priority</span></span>
                </div>

                <div class="detail-row">
                    <span class="detail-key">Yield Metric Yield</span>
                    <span class="detail-val">
                        <div style="font-weight: 600; color: #111111;">@Model.Progress%</div>
                        <div class="progress-bar-container">
                            <div class="progress-bar-fill" style="width: @Model.Progress%"></div>
                        </div>
                    </span>
                </div>

                <div class="section-divider" style="margin-top: 20px;">
                    <span class="section-label">Operational Blueprint</span>
                    <div class="section-line"></div>
                </div>

                <div class="detail-row" style="flex-direction: column; justify-content: flex-start; align-items: flex-start; gap: 6px;">
                    <span class="detail-key">Description/Notes</span>
                    <span class="detail-val" style="text-align: left; font-size: 13px; color: #555555; font-style: @(string.IsNullOrEmpty(Model.Description) ? "italic" : "normal")">
                        @(string.IsNullOrEmpty(Model.Description) ? "No procedural checklists or directive descriptions logged for this task." : Model.Description)
                    </span>
                </div>

            </div>

            <div class="form-actions">
                <a href="/Tasks" class="btn-back">← Back</a>
                <a href="/Tasks/Edit/@Model.TaskId" class="btn-edit">Edit Objective →</a>
            </div>

        </div>
    </div>

</body>
</html>

</table>

<a href="/Tasks/Edit/@Model.TaskId" class="btn btn-warning">Edit</a>
<a href="/Tasks" class="btn btn-secondary">Back</a>