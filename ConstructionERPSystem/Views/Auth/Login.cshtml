@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - Construction ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: #F5F5F0;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 960px;
                min-height: 560px;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 8px 40px rgba(0,0,0,0.12);
            }

            .brand-panel {
                flex: 1;
                background-color: #111111;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 48px 40px;
                position: relative;
                overflow: hidden;
            }

                .brand-panel::before {
                    content: '';
                    position: absolute;
                    top: -60px;
                    right: -60px;
                    width: 220px;
                    height: 220px;
                    border-radius: 50%;
                    background: #F5C518;
                    opacity: 0.08;
                }

                .brand-panel::after {
                    content: '';
                    position: absolute;
                    bottom: -80px;
                    left: -40px;
                    width: 280px;
                    height: 280px;
                    border-radius: 50%;
                    background: #F5C518;
                    opacity: 0.06;
                }

            .brand-logo {
                display: flex;
                align-items: center;
                gap: 12px;
                z-index: 1;
            }

            .brand-icon {
                width: 44px;
                height: 44px;
                background: #F5C518;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .brand-icon svg {
                    width: 24px;
                    height: 24px;
                }

            .brand-name {
                color: #FFFFFF;
                font-size: 18px;
                font-weight: 700;
                letter-spacing: -0.3px;
            }

            .brand-tagline {
                color: #888888;
                font-size: 12px;
            }

            .brand-content {
                z-index: 1;
            }

            .brand-headline {
                color: #FFFFFF;
                font-size: 28px;
                font-weight: 700;
                line-height: 1.3;
                margin-bottom: 16px;
                letter-spacing: -0.5px;
            }

                .brand-headline span {
                    color: #F5C518;
                }

            .brand-desc {
                color: #888888;
                font-size: 14px;
                line-height: 1.7;
            }

            .brand-stats {
                display: flex;
                gap: 24px;
                z-index: 1;
            }

            .stat-number {
                color: #F5C518;
                font-size: 22px;
                font-weight: 700;
                letter-spacing: -0.5px;
            }

            .stat-label {
                color: #666666;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.8px;
            }

            .form-panel {
                flex: 0 0 420px;
                background-color: #FFFFFF;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 52px 44px;
            }

            .form-eyebrow {
                font-size: 11px;
                font-weight: 600;
                color: #F5C518;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                margin-bottom: 8px;
            }

            .form-title {
                font-size: 26px;
                font-weight: 700;
                color: #111111;
                letter-spacing: -0.5px;
                margin-bottom: 6px;
            }

            .form-subtitle {
                font-size: 14px;
                color: #888888;
                margin-bottom: 36px;
            }

            .field-label {
                display: block;
                font-size: 13px;
                font-weight: 500;
                color: #444444;
                margin-bottom: 8px;
            }

            .field-input {
                width: 100%;
                height: 46px;
                padding: 0 16px;
                border: 1.5px solid #E5E5E0;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                color: #111111;
                background: #FAFAF8;
                transition: border-color 0.15s, background 0.15s;
                outline: none;
                margin-bottom: 20px;
            }

                .field-input:focus {
                    border-color: #F5C518;
                    background: #FFFFFF;
                    box-shadow: 0 0 0 4px rgba(245, 197, 24, 0.12);
                }

                .field-input::placeholder {
                    color: #BBBBBB;
                }

            .btn-login {
                width: 100%;
                height: 48px;
                background: #111111;
                color: #FFFFFF;
                border: none;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 15px;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.15s, transform 0.1s;
                margin-top: 4px;
                letter-spacing: -0.2px;
            }

                .btn-login:hover {
                    background: #2a2a2a;
                }

                .btn-login:active {
                    transform: scale(0.99);
                }

            .divider {
                display: flex;
                align-items: center;
                gap: 12px;
                margin: 24px 0;
            }

            .divider-line {
                flex: 1;
                height: 1px;
                background: #E5E5E0;
            }

            .divider-text {
                font-size: 12px;
                color: #BBBBBB;
                font-weight: 500;
            }

            .forgot-link {
                text-align: center;
                font-size: 13px;
                color: #888888;
            }

                .forgot-link a {
                    color: #111111;
                    font-weight: 500;
                    text-decoration: none;
                    border-bottom: 1px solid #E5E5E0;
                    transition: border-color 0.15s;
                }

                    .forgot-link a:hover {
                        border-color: #F5C518;
                    }

            .alert-error {
                background: #FFF3F3;
                border: 1px solid #FFCDD2;
                border-left: 3px solid #E53935;
                border-radius: 8px;
                padding: 12px 16px;
                font-size: 13px;
                color: #B71C1C;
                margin-bottom: 24px;
            }

            @@media (max-width: 768px) {
                .login-wrapper {
                    flex-direction: column;
                    max-width: 440px;
                }

                .brand-panel {
                    padding: 32px 28px;
                    min-height: 200px;
                }

                .brand-headline {
                    font-size: 22px;
                }

                .brand-stats, .brand-desc {
                    display: none;
                }

                .form-panel {
                    flex: unset;
                    width: 100%;
                    padding: 36px 28px;
                }
            }
    </style>
</head>

<body>
    <div class="login-wrapper">

        <div class="brand-panel">
            <div class="brand-logo">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" fill="#111" />
                        <path d="M9 22V12h6v10" stroke="#111" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                </div>
                <div>
                    <div class="brand-name">BuildCore ERP</div>
                    <div class="brand-tagline">Construction Management</div>
                </div>
            </div>

            <div class="brand-content">
                <h2 class="brand-headline">Manage every<br>project with <span>precision.</span></h2>
                <p class="brand-desc">From procurement to payroll, track every resource, timeline, and cost across all your construction sites — in one platform.</p>
            </div>

            <div class="brand-stats">
                <div><div class="stat-number">100+</div><div class="stat-label">Projects</div></div>
                <div><div class="stat-number">98%</div><div class="stat-label">Uptime</div></div>
                <div><div class="stat-number">5K</div><div class="stat-label">Workers</div></div>
            </div>
        </div>

        <div class="form-panel">
            <p class="form-eyebrow">Welcome back</p>
            <h1 class="form-title">Sign in to continue</h1>
            <p class="form-subtitle">Enter your credentials to access your workspace.</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert-error">@ViewBag.Error</div>
            }

            <form method="post">
                <label class="field-label" for="email">Email address</label>
                <input type="email" id="email" name="email" class="field-input" placeholder="you@company.com" required />

                <label class="field-label" for="password">Password</label>
                <input type="password" id="password" name="password" class="field-input" placeholder="••••••••" required />

                <button type="submit" class="btn-login">Sign in →</button>
            </form>

            <div class="divider">
                <div class="divider-line"></div>
                <span class="divider-text">or</span>
                <div class="divider-line"></div>
            </div>

            <p class="forgot-link">Forgot your password? <a href="#">Reset it here</a></p>
        </div>

    </div>
</body>
</html>