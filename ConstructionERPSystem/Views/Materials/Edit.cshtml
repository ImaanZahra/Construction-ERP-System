@model ConstructionERPSystem.Models.Material

<!DOCTYPE html>
<html>
<head>
    <title>Edit Material - Construction ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: #F5F5F0;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 16px;
            }

            .page-wrap {
                width: 100%;
                max-width: 580px;
            }

            .page-eyebrow {
                font-size: 11px;
                font-weight: 600;
                color: #F5C518;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                margin-bottom: 6px;
            }

            .page-title {
                font-size: 26px;
                font-weight: 700;
                color: #111111;
                letter-spacing: -0.5px;
                margin-bottom: 4px;
            }

            .page-subtitle {
                font-size: 14px;
                color: #888888;
                margin-bottom: 24px;
            }

            .card {
                background: #FFFFFF;
                border-radius: 16px;
                box-shadow: 0 8px 40px rgba(0,0,0,0.08);
                overflow: hidden;
            }

            .card-top-bar {
                background: #111111;
                padding: 24px 32px;
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .avatar {
                width: 48px;
                height: 48px;
                background: #F5C518;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                font-weight: 700;
                color: #111111;
                flex-shrink: 0;
            }

            .top-bar-name {
                color: #FFFFFF;
                font-size: 16px;
                font-weight: 700;
                letter-spacing: -0.3px;
            }

            .top-bar-sub {
                color: #888888;
                font-size: 12px;
                margin-top: 2px;
            }

            .form-body {
                padding: 28px 32px;
            }

            .section-divider {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 20px;
            }

            .section-label {
                font-size: 11px;
                font-weight: 600;
                color: #BBBBBB;
                text-transform: uppercase;
                letter-spacing: 1px;
                white-space: nowrap;
            }

            .section-line {
                flex: 1;
                height: 1px;
                background: #E5E5E0;
            }

            .field-group {
                margin-bottom: 20px;
            }

            .field-label {
                display: block;
                font-size: 13px;
                font-weight: 500;
                color: #444444;
                margin-bottom: 8px;
            }

                .field-label span {
                    color: #F5C518;
                    margin-left: 2px;
                }

            .field-input {
                width: 100%;
                height: 46px;
                padding: 0 16px;
                border: 1.5px solid #E5E5E0;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                color: #111111;
                background: #FAFAF8;
                outline: none;
                transition: border-color 0.15s, background 0.15s;
            }

                .field-input:focus {
                    border-color: #F5C518;
                    background: #FFFFFF;
                    box-shadow: 0 0 0 4px rgba(245, 197, 24, 0.12);
                }

            .field-row {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 16px;
            }

            .form-actions {
                display: flex;
                gap: 12px;
                padding: 20px 32px 28px;
                border-top: 1px solid #E5E5E0;
            }

            .btn-update {
                flex: 1;
                height: 48px;
                background: #111111;
                color: #FFFFFF;
                border: none;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 15px;
                font-weight: 600;
                cursor: pointer;
                letter-spacing: -0.2px;
                transition: background 0.15s, transform 0.1s;
            }

                .btn-update:hover {
                    background: #2a2a2a;
                }

                .btn-update:active {
                    transform: scale(0.99);
                }

            .btn-back {
                display: flex;
                align-items: center;
                justify-content: center;
                height: 48px;
                padding: 0 24px;
                background: #FFFFFF;
                color: #444444;
                border: 1.5px solid #E5E5E0;
                border-radius: 10px;
                font-family: 'Inter', sans-serif;
                font-size: 15px;
                font-weight: 500;
                text-decoration: none;
                transition: border-color 0.15s, color 0.15s;
                white-space: nowrap;
            }

                .btn-back:hover {
                    border-color: #111111;
                    color: #111111;
                }

            @@media (max-width: 560px) {
                .card-top-bar, .form-body, .form-actions {
                    padding-left: 20px;
                    padding-right: 20px;
                }

                .field-row {
                    grid-template-columns: 1fr;
                }

                .form-actions {
                    flex-direction: column;
                }
            }
    </style>
</head>
<body>

    <div class="page-wrap">

        <p class="page-eyebrow">Logistics</p>
        <h1 class="page-title">Edit Material</h1>
        <p class="page-subtitle">Modify parameters and inventory configurations for this resource entry.</p>

        <div class="card">

            <!-- Premium Dark Context Header Bar -->
            <div class="card-top-bar">
                <div class="avatar">@Model.MaterialName?.Substring(0, 1).ToUpper()</div>
                <div>
                    <div class="top-bar-name">@Model.MaterialName</div>
                    <div class="top-bar-sub">Material ID &nbsp;#@Model.MaterialId</div>
                </div>
            </div>

            <form method="post">
                <input type="hidden" asp-for="MaterialId" />

                <div class="form-body">

                    <!-- Section 1: Item Definitions -->
                    <div class="section-divider">
                        <span class="section-label">Resource Definition</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="field-group">
                        <label class="field-label" for="MaterialName">Material Name <span>*</span></label>
                        <input asp-for="MaterialName" id="MaterialName" class="field-input" placeholder="e.g. Deformed Steel Bars" required />
                    </div>

                    <div class="field-group">
                        <label class="field-label" for="Unit">Measurement Unit</label>
                        <input asp-for="Unit" id="Unit" class="field-input" placeholder="e.g. Bags, Tons, Units" />
                    </div>

                    <!-- Section 2: Floor Tolerances -->
                    <div class="section-divider" style="margin-top: 8px;">
                        <span class="section-label">Stock Metrics</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label" for="CurrentStock">Current Stock</label>
                            <input asp-for="CurrentStock" id="CurrentStock" type="number" class="field-input" placeholder="0" />
                        </div>
                        <div class="field-group">
                            <label class="field-label" for="MinimumStock">Minimum Safety Stock</label>
                            <input asp-for="MinimumStock" id="MinimumStock" type="number" class="field-input" placeholder="0" />
                        </div>
                    </div>

                </div>

                <!-- Footer System Form Controls -->
                <div class="form-actions">
                    <a href="/Materials" class="btn-back">← Back</a>
                    <button type="submit" class="btn-update">Update Material →</button>
                </div>

            </form>
        </div>
    </div>

</body>
</html>