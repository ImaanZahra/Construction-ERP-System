                </a>
                <a class="nav-link-item" href="/Invoices">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                    Invoices
                </a>
            }

            @if (role == "Contractor")
            {
                <div class="nav-section-label">Overview</div>
                <a class="nav-link-item" href="/Dashboard/Contractor">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                    Dashboard
                </a>
                <div class="nav-section-label">Work</div>
                <a class="nav-link-item" href="/Tasks">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                    Tasks
                </a>
                <a class="nav-link-item" href="/Employees">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" /></svg>
                    Workers
                </a>
                <a class="nav-link-item" href="/Attendance">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    Attendance
                </a>
            }

            @if (role == "Worker" || (role != null && role != "Admin" && role != "Project Manager" && role != "Client" && role != "Store Manager" && role != "Procurement Officer" && role != "HR Manager" && role != "Accountant" && role != "Contractor"))
            {
                <div class="nav-section-label">Overview</div>
                <a class="nav-link-item" href="/Dashboard/@(role == "Worker" ? "Worker" : "Employee")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                    Dashboard
                </a>
                <div class="nav-section-label">My Work</div>
                <a class="nav-link-item" href="/Tasks">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                    My Tasks
                </a>
                <a class="nav-link-item" href="/Attendance">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    My Attendance
                </a>
            }

            @if (role != null)
            {
                <div class="nav-divider"></div>
                <a class="nav-logout" href="/Auth/Logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    Logout
                </a>
            }

        </nav>

        @if (role != null)
        {
            <div class="sidebar-footer">
                <div class="sidebar-user">
                    <div class="user-avatar">@fullName?.Substring(0, 1).ToUpper()</div>
                    <div>
                        <div class="user-name">@fullName</div>
                        <div class="user-role">@role</div>
                    </div>
                </div>
            </div>
        }

    </aside>

    <!-- Main -->
    <div class="main-wrap">

        <header class="topbar">
            <div class="topbar-left">
                <span class="topbar-page-label">@role Dashboard</span>
                <span class="topbar-badge">BuildCore ERP</span>
            </div>
            <div class="topbar-right">
                <span class="topbar-welcome">Welcome, <strong>@fullName</strong></span>
                <div class="topbar-avatar">@fullName?.Substring(0, 1).ToUpper()</div>
            </div>
        </header>

        <main class="page-content">
            @RenderBody()
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>